# Ucab Backend Configuration

# Server Port
PORT=5000

# Environment Mode (development or production)
NODE_ENV=development

# MongoDB Atlas or Local Connection URI
# e.g. mongodb+srv://<username>:<password>@cluster.mongodb.net/ucab
MONGO_URI=mongodb://localhost:27017/ucab

# JWT Secret for Signing Tokens
JWT_SECRET=thisisasecretfallbackfortesting123

# JWT Expiry Time
JWT_EXPIRE=7d
